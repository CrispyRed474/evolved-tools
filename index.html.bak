      `<div style="padding: 12px 16px; border-top: 1px solid var(--border);">
        <label class="field-label">Floor prep notes<small>Optional</small></label>
        <textarea id="prep-notes-${idx}" placeholder="Notes..." style="width: calc(100% - 24px); min-height: 60px; padding: 12px; border: 1.5px solid var(--border); border-radius: 8px; font-family: inherit; font-size: 15px; resize: vertical; outline: none; background: #fafafa; color: var(--text); margin-top: 8px;" oninput="options[${idx}].notes.prep = this.value"></textarea>
      </div>
    </div>
  `;
  
  return html;
}

function switchTab(idx) {
  currentOptionIdx = idx;
  renderOptions();
  calcQuote(idx);
  updateComparisonSummary();
  document.getElementById('tab-content-' + idx).scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function addOption() {
  if (options.length >= 4) return;
  
  // Create new option by copying room sqm values from Option A
  const newOpt = createEmptyOption(options.length);
  if (options.length > 0) {
    // Copy room sqm from Option A (but NOT values, just preserve ability to enter)
    Object.keys(options[0].rooms).forEach(k => {
      newOpt.rooms[k] = { ...options[0].rooms[k], value: 0 }; // Copy unit preference but 0 value
    });
  }
  
  options.push(newOpt);
  currentOptionIdx = options.length - 1;
  extraRoomCounters[options.length - 1] = 0;
  renderOptions();
  switchTab(currentOptionIdx);
}

function toggleOption(idx, key) {
  options[idx].state[key] = !options[idx].state[key];
  const el = document.getElementById('toggle-' + key + '-' + idx);
  if (el) el.classList.toggle('on', options[idx].state[key]);
  
  if (key === 'highrise') {
    const row = document.getElementById('walkup-row-' + idx);
    if (row) row.style.display = options[idx].state[key] ? '' : 'none';
  }
  
  calcQuote(idx);
  updateComparisonSummary();
}

function updateOption(idx) {
  // Update product and prices
  const searchInput = document.getElementById('product-search-' + idx);
  if (!searchInput) return;
  
  const customPriceEl = document.getElementById('custom-price-' + idx);
  const otherNameEl = document.getElementById('other-product-name-' + idx);
  const otherPriceEl = document.getElementById('other-price-' + idx);
  
  const customPrice = customPriceEl ? parseFloat(customPriceEl.value) || 0 : 0;
  const otherName = otherNameEl ? otherNameEl.value.trim() : '';
  const otherPrice = otherPriceEl ? parseFloat(otherPriceEl.value) || 0 : 0;
  
  if (options[idx].product.value === 'custom') {
    options[idx].product.price = customPrice;
  } else if (options[idx].product.value === 'other') {
    options[idx].product.name = otherName || 'Other';
    options[idx].product.price = otherPrice;
  }
}

function filterProducts(idx) {
  const input = document.getElementById('product-search-' + idx);
  const q = (input.value || '').toLowerCase();
  const dd = document.getElementById('product-dropdown-' + idx);
  let html = '';
  let lastGroup = '';
  const filtered = q ? PRODUCTS.filter(p => p.name.toLowerCase().includes(q)) : PRODUCTS;
  
  filtered.forEach(p => {
    if (p.group !== lastGroup) {
      html += `<div class="product-group-label">${p.group}</div>`;
      lastGroup = p.group;
    }
    html += `<div class="product-option" onclick="selectProduct(${idx}, '${p.value}')">
      <span>${p.name}</span>
      <span class="product-option-price">$${p.price > 0 ? p.price.toFixed(2)+'/m²' : 'manual'}</span>
    </div>`;
  });
  
  dd.innerHTML = html || '<div class="product-option" style="color:#888">No results</div>';
}

function showProductDropdown(idx) {
  filterProducts(idx);
  document.getElementById('product-dropdown-' + idx).classList.add('open');
}

function selectProduct(idx, value) {
  const prod = PRODUCTS.find(x => x.value === value);
  if (!prod) return;
  
  options[idx].product = { name: prod.name, value: prod.value, price: prod.price, type: prod.type, isHerr: prod.herr };
  const input = document.getElementById('product-search-' + idx);
  input.value = prod.name;
  document.getElementById('product-dropdown-' + idx).classList.remove('open');
  
  // Show/hide conditional sections
  document.getElementById('custom-price-row-' + idx).style.display = (prod.type === 'custom') ? '' : 'none';
  document.getElementById('other-product-row-' + idx).style.display = (prod.value === 'other') ? '' : 'none';
  document.getElementById('other-price-row-' + idx).style.display = (prod.value === 'other') ? '' : 'none';
  document.getElementById('carpet-section-' + idx).style.display = (prod.type === 'carpet') ? '' : 'none';
  
  const isSheetVinyl = prod.type === 'vinyl' && prod.name && prod.name.toLowerCase().includes('sheet');
  document.getElementById('vinyl-sheet-section-' + idx).style.display = isSheetVinyl ? '' : 'none';
  
  if (prod.isHerr && !options[idx].state.herr) {
    toggleOption(idx, 'herr');
  }
  
  calcQuote(idx);
  updateComparisonSummary();
}

document.addEventListener('click', function(e) {
  if (!e.target.closest('.product-search-wrap')) {
    document.querySelectorAll('.product-dropdown').forEach(dd => dd.classList.remove('open'));
  }
});

function updateRoomValue(idx, roomId, value) {
  options[idx].rooms[roomId].value = parseFloat(value) || 0;
  updateRoomTotal(idx);
  calcQuote(idx);
}

function toggleRoomUnit(idx, roomId) {
  const current = options[idx].rooms[roomId].unit;
  options[idx].rooms[roomId].unit = (current === 'sqm') ? 'lm' : 'sqm';
  const btn = document.getElementById('unit-btn-' + roomId + '-' + idx);
  if (btn) btn.textContent = (options[idx].rooms[roomId].unit === 'sqm') ? 'm²' : 'lm';
  updateRoomTotal(idx);
  calcQuote(idx);
}

function updateRoomTotal(idx) {
  let total = 0;
  Object.values(options[idx].rooms).forEach(r => total += r.value);
  options[idx].extraRooms.forEach(r => total += r.value);
  
  const display = document.getElementById('room-total-display-' + idx);
  if (display) display.textContent = total.toFixed(1) + ' m²';
}

function addExtraRoom(idx) {
  const counter = (extraRoomCounters[idx] || 0) + 1;
  extraRoomCounters[idx] = counter;
  
  const room = { name: 'Other ' + counter, value: 0, unit: 'sqm' };
  options[idx].extraRooms.push(room);
  
  const container = document.getElementById('extra-rooms-container-' + idx);
  const div = document.createElement('div');
  div.className = 'field';
  div.id = 'extra-room-row-' + idx + '-' + counter;
  div.style.alignItems = 'center';
  div.innerHTML = '<label class="field-label">Other</label>' +
    '<input type="text" id="extra-room-name-' + idx + '-' + counter + '" placeholder="Room name" value="' + room.name + '" style="max-width:110px;margin-right:6px" oninput="options[' + idx + '].extraRooms[' + (options[idx].extraRooms.length - 1) + '].name = this.value">' +
    '<input type="number" id="extra-room-sqm-' + idx + '-' + counter + '" placeholder="0" step="0.1" min="0" oninput="options[' + idx + '].extraRooms[' + (options[idx].extraRooms.length - 1) + '].value = parseFloat(this.value)||0; updateRoomTotal(' + idx + '); calcQuote(' + idx + ')" style="max-width:70px">' +
    '<button type="button" onclick="toggleExtraRoomUnit(' + idx + ', ' + (options[idx].extraRooms.length - 1) + ')" style="margin-left:6px;background:#f0f0f0;border:1.5px solid #ddd;border-radius:6px;padding:6px 10px;font-size:12px;color:#555;cursor:pointer;font-weight:600;flex-shrink:0;" id="unit-btn-extra-' + idx + '-' + counter + '">m²</button>' +
    '<button type="button" onclick="removeExtraRoom(' + idx + ', ' + (options[idx].extraRooms.length - 1) + ')" style="margin-left:8px;background:none;border:none;color:#aaa;font-size:18px;cursor:pointer;line-height:1" title="Remove">✕</button>';
  
  container.appendChild(div);
  updateRoomTotal(idx);
}

function removeExtraRoom(idx, roomIdx) {
  options[idx].extraRooms.splice(roomIdx, 1);
  const row = document.getElementById('extra-room-row-' + idx + '-' + (roomIdx + 1));
  if (row) row.remove();
  updateRoomTotal(idx);
  calcQuote(idx);
}

function toggleExtraRoomUnit(idx, roomIdx) {
  const current = options[idx].extraRooms[roomIdx].unit;
  options[idx].extraRooms[roomIdx].unit = (current === 'sqm') ? 'lm' : 'sqm';
  updateRoomTotal(idx);
  calcQuote(idx);
}

function updatePrepValue(idx, prepKey, value) {
  const valMap = {
    'prep-carpet': 'carpet_sqm',
    'prep-hybrid': 'hybrid_sqm',
    'prep-tiles': 'tiles_sqm',
    'prep-glued': 'glued_sqm',
    'prep-grind': 'grind_sqm',
    'prep-flood': 'flood_sqm',
    'prep-ply': 'ply_sqm',
    'prep-smoothedge': 'smoothedge_sqm'
  };
  options[idx].prep[valMap[prepKey]] = parseFloat(value) || 0;
}

function calcQuote(idx) {
  const opt = options[idx];
  const prod = opt.product;
  
  if (!prod.value) {
    document.getElementById('sum-subtotal').textContent = '$0.00';
    document.getElementById('sum-total').textContent = '$0.00';
    document.getElementById('sum-gst').textContent = '$0.00';
    document.getElementById('line-items-wrap').style.display = 'none';
    return;
  }
  
  // Sync form inputs to state for display
  const searchInput = document.getElementById('product-search-' + idx);
  if (searchInput && searchInput.value && !prod.name) {
    prod.name = searchInput.value;
  }
  
  const colourEl = document.getElementById('product-colour-' + idx);
  const colour = colourEl ? colourEl.value.trim() : '';
  
  const isHerr = opt.state.herr || prod.isHerr;
  const type = prod.type;
  let supplyPrice = prod.price;
  
  // Calculate area
  let area = 0;
  Object.values(opt.rooms).forEach(r => area += r.value);
  opt.extraRooms.forEach(r => area += r.value);
  
  const areaWaste = area * 1.10;
  
  const lines = [];
  
  // 1. Supply
  if (area > 0 && supplyPrice > 0) {
    const nameWithColour = colour ? `${prod.name} - ${colour}` : prod.name;
    const cost = areaWaste * supplyPrice;
    lines.push({ name: `${nameWithColour} supply`, detail: `${areaWaste.toFixed(1)}m² (inc 10% waste) × $${supplyPrice.toFixed(2)}`, total: cost });
  }
  
  // 2. Install labour
  if (area > 0 && type !== 'acoustic' && type !== 'custom') {
    const rate = isHerr ? (installRateHerr[type] || installRate[type]) : installRate[type];
    const cost = area * rate;
    lines.push({ name: `${isHerr ? 'Herringbone ' : ''}${capitalize(type)} installation`, detail: `${area.toFixed(1)}m² × $${rate.toFixed(2)}`, total: cost });
  }
  
  // 3-7. Extras, trims, stairs, prep (same logic as original)
  // ... (condensed for brevity - same calculation logic)
  
  // Moisture barrier
  if (opt.state.moisture && area > 0) {
    lines.push({ name: 'Moisture barrier supply & install', detail: `${area.toFixed(1)}m² × $7.14`, total: area * 7.14 });
  }
  
  // Underlay
  if (opt.state.underlay && area > 0) {
    lines.push({ name: 'Underlay supply & install', detail: `${area.toFixed(1)}m² × $7.14`, total: area * 7.14 });
  }
  
  // Trims
  if (opt.trims.scotia_lm > 0) lines.push({ name: 'Scotia', detail: `${opt.trims.scotia_lm}lm × $17.14`, total: opt.trims.scotia_lm * 17.14 });
  if (opt.trims.ltrim_lm > 0) lines.push({ name: 'L Trim supply & install', detail: `${opt.trims.ltrim_lm}lm × $24.29`, total: opt.trims.ltrim_lm * 24.29 });
  if (opt.trims.ttrim_lm > 0) lines.push({ name: 'T Trim supply & install', detail: `${opt.trims.ttrim_lm}lm × $24.29`, total: opt.trims.ttrim_lm * 24.29 });
  if (opt.trims.utrim_lm > 0) lines.push({ name: 'U Trim supply & install', detail: `${opt.trims.utrim_lm}lm × $24.29`, total: opt.trims.utrim_lm * 24.29 });
  if (opt.trims.skirting_exist_lm > 0) lines.push({ name: 'Skirting - remove & refit existing', detail: `${opt.trims.skirting_exist_lm}lm × $12.86`, total: opt.trims.skirting_exist_lm * 12.86 });
  if (opt.trims.skirting_new_lm > 0) lines.push({ name: 'Skirting - remove + supply & fit new', detail: `${opt.trims.skirting_new_lm}lm × $21.43`, total: opt.trims.skirting_new_lm * 21.43 });
  if (opt.trims.stair_risers > 0) lines.push({ name: 'White stair risers', detail: `${opt.trims.stair_risers} × $30.00`, total: opt.trims.stair_risers * 30 });
  
  // Extras
  if (opt.state.toilet) lines.push({ name: 'Toilet cut', detail: 'flat rate', total: 100 });
  if (opt.state.drain) lines.push({ name: 'Drain cut', detail: 'flat rate', total: 100 });
  if (opt.state.highrise) lines.push({ name: 'Unit / Highrise surcharge', detail: 'flat rate', total: 150 });
  if (opt.misc.walkup_floors > 0 && opt.state.highrise) lines.push({ name: 'Walk-up surcharge (no lift)', detail: `${opt.misc.walkup_floors} floors × $50`, total: opt.misc.walkup_floors * 50 });
  
  // Furniture
  if (opt.misc.furniture > 0) lines.push({ name: 'Furniture removal', detail: `${opt.misc.furniture} items × $50.00`, total: opt.misc.furniture * 50 });
  
  // Carpet/vinyl details
  if (opt.carpet.lm > 0 && type === 'carpet') {
    lines.push({ name: 'Carpet supply (lineal metres)', detail: `${opt.carpet.lm}lm`, total: 0 });
  }
  if (opt.carpet.seams > 0 && type === 'carpet') {
    lines.push({ name: 'Carpet seams', detail: `${opt.carpet.seams} seams`, total: 0 });
  }
  if (opt.vinyl.coving_lm > 0) {
    lines.push({ name: 'Vinyl coving', detail: `${opt.vinyl.coving_lm}lm`, total: 0 });
  }
  if (opt.vinyl.welds > 0) {
    lines.push({ name: 'Vinyl welds', detail: `${opt.vinyl.welds} welds`, total: 0 });
  }
  
  // Travel
  if (opt.state.travel) lines.push({ name: 'Travel surcharge (>50km)', detail: 'flat rate', total: 50 });
  
  // Stairs
  if (opt.stairs.straight > 0) lines.push({ name: 'Stair installation - straight', detail: `${opt.stairs.straight} stairs × $85.71`, total: opt.stairs.straight * 85.71 });
  if (opt.stairs.winder > 0) lines.push({ name: 'Stair installation - winder', detail: `${opt.stairs.winder} stairs × $114.29`, total: opt.stairs.winder * 114.29 });
  if (opt.stairs.material_sqm > 0 && type !== 'custom' && type !== 'acoustic') {
    const rate = stairMatRate[type] || 32.86;
    lines.push({ name: 'Stair material supply', detail: `${opt.stairs.material_sqm}m² × $${rate.toFixed(2)}`, total: opt.stairs.material_sqm * rate });
  }
  if (opt.state.nosing && (opt.stairs.straight + opt.stairs.winder) > 0 && type !== 'custom' && type !== 'acoustic') {
    const count = opt.stairs.straight + opt.stairs.winder;
    const rate = stairNosingRate[type] || 42.86;
    lines.push({ name: 'Stair nosing supply', detail: `${count} × $${rate.toFixed(2)}`, total: count * rate });
  }
  
  // Floor prep
  if (opt.prep.carpet_sqm > 0) lines.push({ name: 'Remove & dispose carpet', detail: `${opt.prep.carpet_sqm}m² × $10.00`, total: opt.prep.carpet_sqm * 10 });
  if (opt.prep.hybrid_sqm > 0) lines.push({ name: 'Remove & dispose hybrid/laminate', detail: `${opt.prep.hybrid_sqm}m² × $21.43`, total: opt.prep.hybrid_sqm * 21.43 });
  if (opt.prep.tiles_sqm > 0) lines.push({ name: 'Remove tiles + grind + flood', detail: `${opt.prep.tiles_sqm}m² × $114.29`, total: opt.prep.tiles_sqm * 114.29 });
  if (opt.prep.glued_sqm > 0) lines.push({ name: 'Remove glued floor + grind', detail: `${opt.prep.glued_sqm}m² × $64.29`, total: opt.prep.glued_sqm * 64.29 });
  if (opt.prep.grind_sqm > 0) lines.push({ name: 'Floor prep - grind', detail: `${opt.prep.grind_sqm}m² × $21.43`, total: opt.prep.grind_sqm * 21.43 });
  if (opt.prep.flood_sqm > 0) lines.push({ name: 'Floor prep - flood coat/levelling', detail: `${opt.prep.flood_sqm}m² × $52.86`, total: opt.prep.flood_sqm * 52.86 });
  if (opt.prep.ply_sqm > 0) lines.push({ name: 'Plywood/masonite 5mm supply & install', detail: `${opt.prep.ply_sqm}m² × $64.29`, total: opt.prep.ply_sqm * 64.29 });
  if (opt.prep.smoothedge_sqm > 0) lines.push({ name: 'Smoothedge & glue', detail: `${opt.prep.smoothedge_sqm}m² × $10.00`, total: opt.prep.smoothedge_sqm * 10 });
  
  // Totals
  const subtotal = lines.reduce((s, l) => s + l.total, 0);
  const gst = subtotal * 0.1;
  const total = subtotal + gst;
  
  // Update display only for active option
  if (idx === currentOptionIdx) {
    document.getElementById('sum-subtotal').textContent = fmt(subtotal);
    document.getElementById('sum-total').textContent = fmt(total);
    document.getElementById('sum-gst').textContent = fmt(gst);
    
    const wrap = document.getElementById('line-items-wrap');
    const list = document.getElementById('line-items-list');
    if (lines.length > 0) {
      wrap.style.display = '';
      list.innerHTML = lines.map(l => `
        <div class="line-item">
          <div><div class="li-name">${l.name}</div><div class="li-detail">${l.detail}</div></div>
          <div class="li-price">${fmt(l.total)}<small>ex GST</small></div>
        </div>`).join('');
    } else {
      wrap.style.display = 'none';
    }
  }
  
  // Store for submission
  opt.quoteData = { lines, subtotal, gst, total };
  
  // Update comparison summary
  updateComparisonSummary();
}

function updateComparisonSummary() {
  if (options.length <= 1) {
    document.getElementById('comparison-summary').style.display = 'none';
    return;
  }
  
  document.getElementById('comparison-summary').style.display = '';
  const listEl = document.getElementById('comparison-summary-list');
  listEl.innerHTML = options.map((opt, i) => `
    <div class="comparison-summary-row">
      <span class="comparison-summary-label">${opt.label}</span>
      <span class="comparison-summary-total">${fmt(opt.quoteData.total)}</span>
    </div>
  `).join('');
}

function fmt(n) { return '$' + n.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ','); }
function capitalize(s) { return s ? s[0].toUpperCase() + s.slice(1) : ''; }

// ── Multi-photo upload ──
window._photos = {};
window._photoCounter = 0;

function compressImage(file, maxWidth, quality) {
  return new Promise((resolve) => {
    const reader = new FileReader();
    reader.onload = (e) => {
      const img = new Image();
      img.onload = () => {
        const canvas = document.createElement('canvas');
        let w = img.width, h = img.height;
        if (w > maxWidth) { h = h * (maxWidth / w); w = maxWidth; }
        canvas.width = w;
        canvas.height = h;
        const ctx = canvas.getContext('2d');
        ctx.drawImage(img, 0, 0, w, h);
        resolve(canvas.toDataURL('image/jpeg', quality));
      };
      img.src = e.target.result;
    };
    reader.readAsDataURL(file);
  });
}

async function onMultiPhotoSelect(input) {
  if (!input.files || !input.files.length) return;
  const btn = document.querySelector('.btn-photo');
  if (btn) btn.innerHTML = '⏳ Compressing...';
  
  const files = Array.from(input.files);
  for (const file of files) {
    const compressed = await compressImage(file, 800, 0.7);
    const key = 'site_photo_' + (++window._photoCounter);
    window._photos[key] = compressed;
  }
  
  input.value = '';
  if (btn) btn.innerHTML = '📷 Add Photos';
  renderPhotoThumbs();
}

function removePhoto(key) {
  delete window._photos[key];
  renderPhotoThumbs();
}

function renderPhotoThumbs() {
  const container = document.getElementById('photo-thumbs');
  const countEl = document.getElementById('photo-count');
  const keys = Object.keys(window._photos);
  
  container.innerHTML = keys.map(function(key) {
    return '<div class="photo-thumb">' +
      '<img src="' + window._photos[key] + '" alt="Site photo">' +
      '<button type="button" class="photo-thumb-remove" onclick="removePhoto(\'' + key + '\')">×</button>' +
      '</div>';
  }).join('');
  
  countEl.textContent = keys.length ? keys.length + ' photo' + (keys.length > 1 ? 's' : '') + ' attached' : '';
}

// ── Submit ──
function acceptQuote() {
  const name = document.getElementById('customer-name').value.trim();
  const phone = document.getElementById('customer-phone').value.trim();
  const email = document.getElementById('customer-email').value.trim();
  const address = document.getElementById('customer-address').value.trim();
  const siteNotes = document.getElementById('site-notes').value.trim();
  
  if (!name) { showToast('Please enter customer name'); return; }
  if (!address) { showToast('Please enter job address'); return; }
  
  // Check at least one option has a product selected
  let hasProduct = false;
  options.forEach(opt => {
    if (opt.product.value) hasProduct = true;
  });
  if (!hasProduct) { showToast('Please select a product for at least one option'); return; }
  
  // Check at least one option has total > 0
  let hasTotal = false;
  options.forEach(opt => {
    if (opt.quoteData && opt.quoteData.total > 0) hasTotal = true;
  });
  if (!hasTotal) { showToast('Quote total is $0 - please check inputs'); return; }
  
  showToast('Submitting quote...');
  
  // Build multi-option payload
  const payload = {
    customer: {
      name: name,
      phone: phone,
      email: email,
      address: address
    },
    options: options.map(opt => ({
      label: opt.label,
      product: opt.product.name,
      colour: opt.colour,
      rooms: Object.entries(opt.rooms).reduce((acc, [k, v]) => {
        acc[k] = v;
        return acc;
      }, {}),
      extra_rooms: opt.extraRooms,
      carpet_lm: opt.carpet.lm,
      carpet_seams: opt.carpet.seams,
      vinyl_coving_lm: opt.vinyl.coving_lm,
      vinyl_welds: opt.vinyl.welds,
      trims: opt.trims,
      stairs: opt.stairs,
      prep: opt.prep,
      misc: opt.misc,
      flooring_notes: opt.notes.flooring,
      rooms_notes: opt.notes.rooms,
      trims_notes: opt.notes.trims,
      prep_notes: opt.notes.prep,
      total_ex_gst: Math.round(opt.quoteData.subtotal * 100) / 100,
      total_inc_gst: Math.round(opt.quoteData.total * 100) / 100
    })),
    site_notes: siteNotes,
    customer_notes: document.getElementById('customer-notes').value.trim(),
    region: new URLSearchParams(window.location.search).get('region') === 'bb' ? 'bb' : 'seq',
    photos: window._photos || {},
    submitted_at: new Date().toISOString()
  };
  
  const WORKER_URL = 'https://evolved-quote-worker.richard-b94.workers.dev';
  
  fetch(WORKER_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload)
  })
  .then(response => {
    if (!response.ok) throw new Error(`HTTP ${response.status}`);
    return response.json();
  })
  .then(data => {
    console.log('GHL webhook success:', data);
    showConfirmation({
      name: name,
      address: address,
      optionCount: options.length,
      totalPrice: options.reduce((s, opt) => s + opt.quoteData.total, 0)
    });
  })
  .catch(error => {
    console.error('GHL webhook error:', error);
    showToast('Error submitting quote. Please try again.');
  });
}

function showConfirmation(details) {
  const overlay = document.createElement('div');
  overlay.className = 'confirmation-overlay';
  const totalPrice = details.totalPrice;
  overlay.innerHTML = `
    <div class="confirmation-card">
      <div class="confirmation-icon">✅</div>
      <h2 class="confirmation-title">Quote Submitted</h2>
      <p class="confirmation-message">Your quote${details.optionCount > 1 ? 's' : ''} ${details.optionCount > 1 ? 'have' : 'has'} been submitted successfully. We'll be in touch shortly.</p>
      <div class="confirmation-details">
        <div class="confirmation-detail-row">
          <span class="confirmation-detail-label">Customer</span>
          <span class="confirmation-detail-value">${details.name}</span>
        </div>
        <div class="confirmation-detail-row">
          <span class="confirmation-detail-label">Address</span>
          <span class="confirmation-detail-value" style="text-align: right;">${details.address}</span>
        </div>
        <div class="confirmation-detail-row">
          <span class="confirmation-detail-label">Options</span>
          <span class="confirmation-detail-value">${details.optionCount}</span>
        </div>
        <div class="confirmation-detail-row">
          <span class="confirmation-detail-label">Total</span>
          <span class="confirmation-detail-value">${fmt(totalPrice)}</span>
        </div>
      </div>
      <button class="btn-new-quote" onclick="window.location.reload()">Create New Quote</button>
    </div>
  `;
  document.body.appendChild(overlay);
  const toast = document.getElementById('toast');
  if (toast) toast.classList.remove('show');
}

function geolocateAddress() {
  const btn = document.getElementById('geo-btn');
  const status = document.getElementById('geo-status');
  if (!navigator.geolocation) {
    status.textContent = 'Geolocation not supported on this device.';
    return;
  }
  btn.textContent = '⏳';
  btn.disabled = true;
  status.textContent = 'Getting location...';
  navigator.geolocation.getCurrentPosition(
    async (pos) => {
      const { latitude, longitude } = pos.coords;
      try {
        const r = await fetch(
          `https://nominatim.openstreetmap.org/reverse?lat=${latitude}&lon=${longitude}&format=json&addressdetails=1`,
          { headers: { 'Accept-Language': 'en-AU' } }
        );
        const data = await r.json();
        const a = data.address || {};
        const streetNumber = a.house_number || '';
        const street = a.road || a.pedestrian || '';
        const suburb = a.suburb || a.village || a.town || a.city || '';
        const state = a.state_code || a.state || '';
        const postcode = a.postcode || '';
        const parts = [streetNumber + (streetNumber && street ? ' ' : '') + street, suburb, state, postcode].filter(Boolean);
        const address = parts.join(', ');
        document.getElementById('customer-address').value = address;
        status.textContent = '✅ Location detected - confirm if correct';
        status.style.color = '#2a7a2a';
      } catch(e) {
        status.textContent = 'Could not look up address. Enter manually.';
        status.style.color = '#c00';
      }
      btn.textContent = '📍';
      btn.disabled = false;
    },
    (err) => {
      btn.textContent = '📍';
      btn.disabled = false;
      status.textContent = err.code === 1 ? 'Location permission denied. Enter address manually.' : 'Could not get location. Enter manually.';
      status.style.color = '#c00';
    },
    { enableHighAccuracy: true, timeout: 10000 }
  );
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}

// Init
initOptions();
</script>
</body>
</html>
