// ── State ──
const options = [];
const optionLabels = ['Option A', 'Option B', 'Option C', 'Option D'];
let currentOptionIdx = 0;
let extraRoomCounters = {}; // Track per-option extra rooms

// Initialize with Option A
function initOptions() {
  options.push(createEmptyOption(0));
  renderOptions();
  switchTab(0);
}

function createEmptyOption(idx) {
  return {
    label: optionLabels[idx] || ('Option ' + String.fromCharCode(65 + idx)),
    state: { herr: false, moisture: false, underlay: false, nosing: false, travel: false, toilet: false, drain: false, highrise: false },
    product: { name: '', value: '', price: 0, type: '', isHerr: false },
    colour: '',
    rooms: {
      'room-bed1': { value: 0, unit: 'sqm' },
      'room-bed2': { value: 0, unit: 'sqm' },
      'room-bed3': { value: 0, unit: 'sqm' },
      'room-bed4': { value: 0, unit: 'sqm' },
      'room-living': { value: 0, unit: 'sqm' },
      'room-kitchen': { value: 0, unit: 'sqm' },
      'room-hallway': { value: 0, unit: 'sqm' },
    },
    extraRooms: [],
    carpet: { lm: 0, seams: 0 },
    vinyl: { coving_lm: 0, welds: 0 },
    trims: {
      scotia_lm: 0, ltrim_lm: 0, ttrim_lm: 0, utrim_lm: 0,
      skirting_exist_lm: 0, skirting_new_lm: 0, stair_risers: 0
    },
    stairs: {
      straight: 0, winder: 0, material_sqm: 0
    },
    prep: {
      carpet_sqm: 0, hybrid_sqm: 0, tiles_sqm: 0, glued_sqm: 0,
      grind_sqm: 0, flood_sqm: 0, ply_sqm: 0, smoothedge_sqm: 0
    },
    misc: {
      furniture: 0, walkup_floors: 0, custom_price: 0, other_product_name: ''
    },
    notes: {
      flooring: '', rooms: '', trims: '', prep: ''
    },
    quoteData: { lines: [], subtotal: 0, gst: 0, total: 0 }
  };
}

function renderOptions() {
  const container = document.getElementById('options-container');
  container.innerHTML = '';
  
  options.forEach((opt, idx) => {
    const tab = document.createElement('div');
    tab.className = 'tab-content' + (idx === currentOptionIdx ? ' active' : '');
    tab.id = 'tab-content-' + idx;
    tab.innerHTML = renderOptionContent(idx);
    container.appendChild(tab);
  });
  
  // Update tab buttons
  const tabBar = document.getElementById('tab-bar');
  const buttons = tabBar.querySelectorAll('.tab-btn');
  buttons.forEach((btn, i) => {
    if (i < options.length) {
      btn.textContent = options[i].label;
      btn.classList.toggle('active', i === currentOptionIdx);
    }
  });
  
  // Show/hide add button
  const addBtn = document.getElementById('add-option-btn');
  addBtn.style.display = options.length < 4 ? '' : 'none';
  
  // Add new tab buttons if needed
  if (buttons.length < options.length) {
    for (let i = buttons.length; i < options.length; i++) {
      const btn = document.createElement('button');
      btn.className = 'tab-btn' + (i === currentOptionIdx ? ' active' : '');
      btn.textContent = options[i].label;
      btn.dataset.option = i;
      btn.onclick = () => switchTab(i);
      tabBar.insertBefore(btn, addBtn);
    }
  }
}

function renderOptionContent(idx) {
  const opt = options[idx];
  let html = `
    <div class="section">
      <div class="option-label-row">
        <input type="text" id="option-label-${idx}" value="${opt.label}" placeholder="Option label" onchange="options[${idx}].label = this.value; renderOptions();">
      </div>
    </div>
    <div class="section">
      <div class="section-header">
        <span class="section-icon">🪵</span>
        <span class="section-title">Flooring</span>
      </div>
      <div class="field">
        <label class="field-label">Product</label>
        <div class="product-search-wrap">
          <input type="text" id="product-search-${idx}" class="product-search-input" placeholder="Search products..." autocomplete="off" 
            oninput="filterProducts(${idx})" onfocus="showProductDropdown(${idx})">
          <div class="product-dropdown" id="product-dropdown-${idx}"></div>
        </div>
      </div>
      <div class="field" id="custom-price-row-${idx}" style="display:none">
        <label class="field-label">Custom Price<small>per m2</small></label>
        <input type="number" id="custom-price-${idx}" placeholder="0.00" step="0.01" min="0" oninput="updateOption(${idx}); calcQuote(${idx})">
        <span class="field-unit">$</span>
      </div>
      <div class="field" id="other-product-row-${idx}" style="display:none">
        <label class="field-label">Product Name</label>
        <input type="text" id="other-product-name-${idx}" placeholder="e.g. Special order" oninput="updateOption(${idx}); calcQuote(${idx})">
      </div>
      <div class="field" id="other-price-row-${idx}" style="display:none">
        <label class="field-label">Price<small>per m2</small></label>
        <input type="number" id="other-price-${idx}" placeholder="0.00" step="0.01" min="0" oninput="updateOption(${idx}); calcQuote(${idx})">
        <span class="field-unit">$</span>
      </div>
      <div class="field">
        <label class="field-label">Colour / Shade</label>
        <input type="text" id="product-colour-${idx}" placeholder="e.g. Arctic Oak" oninput="options[${idx}].colour = this.value; calcQuote(${idx})">
      </div>
      <div class="field">
        <label class="field-label">Flooring notes<small>Optional</small></label>
        <textarea id="flooring-notes-${idx}" placeholder="Notes..." style="width: calc(100% - 24px); min-height: 60px; padding: 12px; border: 1.5px solid var(--border); border-radius: 8px; font-family: inherit; font-size: 15px; resize: vertical; outline: none; background: #fafafa; color: var(--text);" oninput="options[${idx}].notes.flooring = this.value"></textarea>
      </div>
    </div>
    <div class="section">
      <div class="section-header">
        <span class="section-icon">📐</span>
        <span class="section-title">Room Areas</span>
      </div>` +
      ['room-bed1', 'room-bed2', 'room-bed3', 'room-bed4'].map(rid => `
      <div class="field">
        <label class="field-label">${rid === 'room-bed1' ? 'Bedroom 1' : rid === 'room-bed2' ? 'Bedroom 2' : rid === 'room-bed3' ? 'Bedroom 3' : 'Bedroom 4'}</label>
        <input type="number" id="${rid}-${idx}" placeholder="0" step="0.1" min="0" oninput="updateRoomValue(${idx}, '${rid}', this.value); calcQuote(${idx})">
        <button type="button" onclick="toggleRoomUnit(${idx}, '${rid}')" style="margin-left:6px;background:#f0f0f0;border:1.5px solid #ddd;border-radius:6px;padding:6px 10px;font-size:12px;color:#555;cursor:pointer;font-weight:600;flex-shrink:0;" id="unit-btn-${rid}-${idx}">m²</button>
      </div>
      `).join('') +
      ['room-living', 'room-kitchen', 'room-hallway'].map(rid => `
      <div class="field">
        <label class="field-label">${rid === 'room-living' ? 'Living / Dining' : rid === 'room-kitchen' ? 'Kitchen' : 'Hallway / Entry'}</label>
        <input type="number" id="${rid}-${idx}" placeholder="0" step="0.1" min="0" oninput="updateRoomValue(${idx}, '${rid}', this.value); calcQuote(${idx})">
        <button type="button" onclick="toggleRoomUnit(${idx}, '${rid}')" style="margin-left:6px;background:#f0f0f0;border:1.5px solid #ddd;border-radius:6px;padding:6px 10px;font-size:12px;color:#555;cursor:pointer;font-weight:600;flex-shrink:0;" id="unit-btn-${rid}-${idx}">m²</button>
      </div>
      `).join('') +
      `<div id="extra-rooms-container-${idx}"></div>
      <div style="padding:4px 0 8px 0">
        <button type="button" onclick="addExtraRoom(${idx})" style="background:#f0f0f0;border:1.5px dashed #bbb;border-radius:8px;padding:8px 18px;font-size:14px;color:#555;cursor:pointer;width:100%">＋ Add Room</button>
